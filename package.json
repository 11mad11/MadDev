{
  "name": "mad",
  "version": "1.0.0-alpha.0",
  "description": "Linux-native SSH gateway helper (CLI + privileged daemon)",
  "main": "src/cli.ts",
  "module": "src/cli.ts",
  "type": "module",
  "scripts": {
    "start": "bun run --watch src/cli.ts",
    "daemon": "sudo bun run src/cli.ts daemon",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "changeset": "changeset"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it@17/schema/release-it.json",
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.1",
    "@inquirer/type": "^4.0.7",
    "@types/sshpk": "^1.17.4",
    "chalk": "^5.6.2",
    "sshpk": "^1.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/bun": "^1.3.14",
    "release-it": "^17.10.0",
    "typescript": "^5.9.3"
  }
}
