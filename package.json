{
  "name": "mad",
  "version": "1.0.0-beta.3",
  "description": "Linux-native SSH gateway helper (CLI + privileged daemon)",
  "main": "src/cli.ts",
  "module": "src/cli.ts",
  "type": "module",
  "scripts": {
    "start": "bun run --watch src/cli.ts",
    "daemon": "sudo bun run src/cli.ts daemon",
    "typecheck": "tsc --noEmit",
    "build": "bash scripts/ensure-vendor-stubs.sh && bun build --compile ./src/cli.ts --outfile=dist/mad",
    "build:linux": "bash scripts/ensure-vendor-stubs.sh && bun build --compile --target=bun-linux-x64 ./src/cli.ts --outfile=dist/mad-linux-x64",
    "build:macos-x64": "bash scripts/ensure-vendor-stubs.sh && bun build --compile --target=bun-darwin-x64 ./src/cli.ts --outfile=dist/mad-darwin-x64",
    "build:macos-arm": "bash scripts/ensure-vendor-stubs.sh && bun build --compile --target=bun-darwin-arm64 ./src/cli.ts --outfile=dist/mad-darwin-arm64",
    "build:windows-native": "cd native/windows-tap && cargo build --release --target x86_64-pc-windows-gnu",
    "build:windows": "bun run build:windows-native && bun build --compile --target=bun-windows-x64 ./src/cli.ts --outfile=dist/mad-windows-x64.exe",
    "smoke:windows-native": "bun run scripts/smoke-windows-native.ts",
    "build:all": "bun run build:linux && bun run build:macos-x64 && bun run build:macos-arm && bun run build:windows",
    "release": "release-it",
    "changeset": "changeset"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it@17/schema/release-it.json",
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.1",
    "@inquirer/type": "^4.0.7",
    "@types/sshpk": "^1.17.4",
    "chalk": "^5.6.2",
    "sshpk": "^1.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/bun": "^1.3.14",
    "release-it": "^17.10.0",
    "typescript": "^5.9.3"
  }
}
