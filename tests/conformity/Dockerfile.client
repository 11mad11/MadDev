FROM debian:bookworm-slim

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
        openssh-client iproute2 iputils-ping tcpdump iperf3 curl unzip netcat-openbsd \
        ca-certificates jq procps net-tools xxd \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://bun.sh/install | bash \
    && install -m 0755 /root/.bun/bin/bun /usr/local/bin/bun

RUN printf '#!/bin/bash\nexec /usr/local/bin/bun /mad/src/cli.ts "$@"\n' > /usr/bin/mad && chmod 755 /usr/bin/mad

COPY init/client-init.sh /init.sh
RUN chmod +x /init.sh

ENTRYPOINT ["/init.sh"]
