{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "downlevelIteration": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "noEmit": true,
        "lib": ["ES2022"],
        "types": ["bun"]
    },
    "include": ["src/**/*.ts"]
}
